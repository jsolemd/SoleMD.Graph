{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "useUnknownInCatchVariables": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "@solemd/api-client": [
        "../../packages/api-client/src/index.ts"
      ],
      "@solemd/api-client/*": [
        "../../packages/api-client/src/*"
      ],
      "@solemd/graph": [
        "../../packages/graph/src/index.ts"
      ],
      "@solemd/graph/*": [
        "../../packages/graph/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "__tests__",
    "**/__tests__",
    "jest.setup.ts",
    "**/scripts",
    "archive",
    "examples"
  ]
}
