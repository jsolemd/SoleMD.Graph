# SoleMD.Graph 1Password Environment variable inventory
# Canonical secret workflow:
#   1. Put the secret-bearing variables below into the Graph 1Password
#      Environment.
#   2. Keep only non-secret local defaults in `.env.local` when the project
#      needs them.
#   3. Keep the non-secret Environment IDs in `~/.config/solemd/1password-env.sh`.
#   4. Run commands with `solemd op-run graph -- <cmd>`.
#
# This file is documentation only. Keep secret-bearing values in 1Password and
# keep only non-secret local defaults in `.env.local`.

# PostgreSQL (local Docker — started via docker/compose.yaml)
# Use 127.0.0.1 instead of localhost on Windows/WSL to avoid IPv6 loopback stalls.
DATABASE_URL=postgresql://solemd:solemd_local@127.0.0.1:5433/solemd_graph

# Redis (local Docker — started via docker/compose.yaml; password comes from compose)
REDIS_URL=redis://:local_dev@127.0.0.1:6380/0

# Semantic Scholar API (free key: https://www.semanticscholar.org/product/api)
S2_API_KEY=your_key_here

# LLM Providers (for RAG synthesis and cluster labeling)
GEMINI_API_KEY=your_key_here
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_key_here

# Langfuse (local SoleMD.Infra instance)
LANGFUSE_BASE_URL=http://127.0.0.1:3100
LANGFUSE_HOST=http://127.0.0.1:3100
LANGFUSE_PUBLIC_KEY=pk-lf-your_key_here
LANGFUSE_SECRET_KEY=sk-lf-your_key_here
LANGFUSE_TRACING_ENVIRONMENT=development
LANGFUSE_FLUSH_AT=1
LANGFUSE_FLUSH_INTERVAL=1

# Graph build artifacts / warehouse root (NVIDIA Workbench ext4 mount)
GRAPH_DIR=/mnt/solemd-graph
GRAPH_STORAGE_HOST_ROOT=/mnt/solemd-graph
GRAPH_POSTGRES_HOST_ROOT=/mnt/solemd-graph/pg-data

# Data directories
# Keep curated repo inputs in `data/`; point large corpora at the warehouse root.
DATA_DIR=data
PUBTATOR_DIR=/mnt/solemd-graph/data/pubtator
SEMANTIC_SCHOLAR_DIR=/mnt/solemd-graph/data/semantic-scholar
PUBTATOR_RELEASE_ID=2026-03-21
S2_RELEASE_ID=2026-03-10

# Model cache
# Keep Hugging Face cache state off-repo on the warehouse disk.
RAG_MODEL_CACHE_DIR=/mnt/solemd-graph/cache/huggingface/hub
HF_HOME=/mnt/solemd-graph/cache/huggingface
HF_HUB_CACHE=/mnt/solemd-graph/cache/huggingface/hub
HF_ASSETS_CACHE=/mnt/solemd-graph/cache/huggingface/assets
HF_XET_CACHE=/mnt/solemd-graph/cache/huggingface/xet
