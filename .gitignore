coverage/
*.lcov
.nyc_output

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*


# Environment files
.env*
!.env.example
.env.local
.env.development.local
.env.test.local
.env.production.local

