# SoleMD.Graph backend rebuild scaffold
#
# Copy to `.env` for local host-run API/worker smoke tests. These values target
# the local compose stack published on loopback. Container-to-container deploys
# can swap the hosts back to the internal service names.

APP_ENV=development
LOG_LEVEL=INFO

API_HOST=127.0.0.1
API_PORT=8010
API_READINESS_TIMEOUT_SECONDS=1.0

WORKER_REDIS_NAMESPACE=solemd-graph
WORKER_STARTUP_TIMEOUT_SECONDS=1.0
WORKER_METRICS_ENABLED=true
WORKER_METRICS_HOST=0.0.0.0
# Leave WORKER_METRICS_PORT unset for queue-owned local scopes:
# ingest=9464, corpus=9465, evidence=9466. The CLI uses its own
# multiprocess scope for direct runs/tests but is not a standing scrape target.
WORKER_METRICS_PORT=
WORKER_METRICS_PORT_BASE=9464
WORKER_METRICS_MULTIPROC_DIR=.state/prometheus
WORKER_METRICS_CLEAN_ON_BOOT=true
POOL_INGEST_MIN=8
POOL_INGEST_MAX=64
POOL_WAREHOUSE_READ_MIN=2
POOL_WAREHOUSE_READ_MAX=8
POOL_SERVE_READ_MIN=2
POOL_SERVE_READ_MAX=16
POOL_ADMIN_MIN=1
POOL_ADMIN_MAX=2
WAREHOUSE_READ_COMMAND_TIMEOUT_SECONDS=300
SERVE_READ_COMMAND_TIMEOUT_SECONDS=5
ADMIN_STATEMENT_CACHE_SIZE=128

GRAPH_DB_WAREHOUSE_HOST_PORT=54432
GRAPH_DB_SERVE_HOST_PORT=55432
PGBOUNCER_SERVE_HOST_PORT=56432
GRAPH_REDIS_HOST_PORT=57379

GRAPH_DB_WAREHOUSE_POSTGRES_DB=warehouse
GRAPH_DB_WAREHOUSE_POSTGRES_USER=postgres
GRAPH_DB_WAREHOUSE_POSTGRES_PASSWORD=postgres
GRAPH_DB_SERVE_POSTGRES_DB=serve
GRAPH_DB_SERVE_POSTGRES_USER=postgres
GRAPH_DB_SERVE_POSTGRES_PASSWORD=postgres
PGBOUNCER_AUTH_PASSWORD=pgbouncer_auth

# Slice 4 wires the real serve role split: engine_serve_read runs through
# PgBouncer; engine_admin stays direct to PostgreSQL for DDL/cutover paths.
SERVE_DSN_READ=postgresql://engine_serve_read:engine_serve_read@127.0.0.1:56432/serve?application_name=graph-engine-api
SERVE_DSN_ADMIN=postgresql://engine_admin:engine_admin@127.0.0.1:55432/serve?application_name=graph-engine-api-admin

# Slice 5 wires the warehouse role split on the direct PostgreSQL surface.
WAREHOUSE_DSN_INGEST=postgresql://engine_ingest_write:engine_ingest_write@127.0.0.1:54432/warehouse?application_name=graph-worker-ingest
WAREHOUSE_DSN_READ=postgresql://engine_warehouse_read:engine_warehouse_read@127.0.0.1:54432/warehouse?application_name=graph-worker-warehouse-read
WAREHOUSE_DSN_ADMIN=postgresql://engine_warehouse_admin:engine_warehouse_admin@127.0.0.1:54432/warehouse?application_name=schema-migrations-warehouse

REDIS_URL=redis://127.0.0.1:57379/0

# Targeted full-text refresh uses the NCBI PMC BioC and PubMed metadata APIs.
NCBI_API_TOOL=solemd_graph_worker
NCBI_API_EMAIL=noreply@example.com
NCBI_API_TIMEOUT_SECONDS=30
