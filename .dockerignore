# SoleMD.Graph — Docker build context exclusions
# Build context is repo root (docker compose context: ..)
# Only docker/graph/Dockerfile and docker/graph/entrypoint.sh are needed.

node_modules/
.next/
out/
build/
dist/
test-results/
coverage/
data/

# Development artifacts
*.log
.env*
!.env.example
.git/
.vscode/
.claude/

# Python venv (managed by named volume at runtime)
engine/.venv/
**/__pycache__/

# HuggingFace model cache (downloaded at runtime, contains git-lfs symlinks)
engine/data/

# Documentation and config not needed in build
docs/
*.md
!docker/**
