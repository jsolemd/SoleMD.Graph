{
  "name": "@solemd/ai-for-md-foundations",
  "version": "1.0.0",
  "description": "AI for MD Foundations education module with content migration utilities",
  "private": true,
  "scripts": {
    "migrate": "tsx scripts/migrate-content.ts migrate",
    "migrate:dry-run": "tsx scripts/migrate-content.ts migrate --dry-run",
    "migrate:force": "tsx scripts/migrate-content.ts migrate --force",
    "migrate:strict": "tsx scripts/migrate-content.ts migrate --strict",
    "validate": "tsx scripts/migrate-content.ts validate",
    "validate:report": "tsx scripts/migrate-content.ts validate --report ./migration-report.md",
    "rollback": "tsx scripts/migrate-content.ts rollback",
    "rollback:list": "tsx scripts/migrate-content.ts rollback --list",
    "analyze": "tsx scripts/migrate-content.ts analyze",
    "analyze:report": "tsx scripts/migrate-content.ts analyze --output ./analysis-report.md",
    "test:migration": "npm run migrate:dry-run && npm run validate",
    "clean:backups": "rm -rf migration-backups",
    "build": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next": "^14.0.0",
    "@mantine/core": "^8.1.3",
    "@mantine/hooks": "^8.1.3",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.294.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.0",
    "inquirer": "^9.2.0",
    "@types/inquirer": "^9.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "education",
    "medical",
    "ai",
    "migration",
    "solemd"
  ],
  "author": "Dr. Jon Sole",
  "license": "MIT"
}
