# SoleMD.Graph Environment Variables
# Copy to .env.local and fill in API keys

# PostgreSQL (local Docker — started via docker/compose.yaml)
# Use 127.0.0.1 instead of localhost on Windows/WSL to avoid IPv6 loopback stalls.
DATABASE_URL=postgresql://solemd:solemd_local@127.0.0.1:5433/solemd_graph

# Redis (local Docker — started via docker/compose.yaml)
REDIS_URL=redis://127.0.0.1:6380/0

# Semantic Scholar API (free key: https://www.semanticscholar.org/product/api)
S2_API_KEY=your_key_here

# LLM Providers (for RAG synthesis and cluster labeling)
GEMINI_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Data directories
DATA_DIR=data
PUBTATOR_DIR=data/pubtator
S2_DIR=data/semantic-scholar
