#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENGINE_DIR="${ROOT_DIR}/engine"
SESSION_NAME="solemd-graph"
LEGACY_SESSION_NAME="solemd-graph-dev"
FRONTEND_PORT="${FRONTEND_PORT:-3000}"
ENGINE_PORT="${ENGINE_PORT:-8300}"
SESSION_RETENTION_DAYS="${SESSION_RETENTION_DAYS:-7}"
GRAPH_DEV_AUTOCLEAN="${GRAPH_DEV_AUTOCLEAN:-1}"
SOLEMD_SCRIPT="/workspaces/SoleMD.Infra/scripts/solemd.sh"

FRONTEND_CMD="source '${SOLEMD_SCRIPT}' && solemd op-run graph -- env PORT='${FRONTEND_PORT}' npm run dev"
ENGINE_CMD="source '${SOLEMD_SCRIPT}' && solemd op-run graph -- bash -lc 'cd engine && uv run uvicorn app.main:app --host 0.0.0.0 --port ${ENGINE_PORT}'"

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Missing required command: $1" >&2
    exit 1
  fi
}

require_cmd tmux
require_cmd npm
require_cmd uv
require_cmd ss
require_cmd pkill
require_cmd python3

listener_pid() {
  local port="$1"
  python3 - "$port" <<'PY'
import re
import subprocess
import sys

port = sys.argv[1]
result = subprocess.run(
    ["ss", "-ltnp"],
    check=False,
    capture_output=True,
    text=True,
)
pattern = re.compile(rf":{re.escape(port)}\b")
for line in result.stdout.splitlines():
    if not pattern.search(line):
        continue
    match = re.search(r'pid=(\d+)', line)
    if match:
        print(match.group(1))
        raise SystemExit(0)
raise SystemExit(1)
PY
}

pid_command() {
  local pid="$1"
  ps -p "$pid" -o command= 2>/dev/null || true
}

process_cwd() {
  local pid="$1"
  readlink -f "/proc/${pid}/cwd" 2>/dev/null || true
}

graph_process_pids() {
  local kind="$1"
  python3 - "${ROOT_DIR}" "${ENGINE_DIR}" "${kind}" <<'PY'
import os
import sys
from pathlib import Path

root_dir = Path(sys.argv[1]).resolve()
engine_dir = Path(sys.argv[2]).resolve()
kind = sys.argv[3]

for proc_name in os.listdir("/proc"):
    if not proc_name.isdigit():
        continue
    pid = int(proc_name)
    try:
        cwd = Path(os.readlink(f"/proc/{pid}/cwd")).resolve()
        cmdline_raw = Path(f"/proc/{pid}/cmdline").read_bytes()
    except (FileNotFoundError, PermissionError, OSError):
        continue
    cmd = cmdline_raw.replace(b"\x00", b" ").decode("utf-8", "ignore").strip()
    if not cmd:
        continue
    if kind == "frontend":
        if cwd == root_dir and (
            "next dev" in cmd
            or "next start" in cmd
            or "next-server" in cmd
            or "npm run dev" in cmd
            or "npm run start" in cmd
        ):
            print(pid)
    elif kind == "engine":
        if cwd == engine_dir and "uvicorn" in cmd and "app.main:app" in cmd:
            print(pid)
PY
}

prune_history() {
  python3 - "${SESSION_RETENTION_DAYS}" <<'PY'
import os
import shutil
import sys
import time
from pathlib import Path

retention_days = int(sys.argv[1])
cutoff = time.time() - retention_days * 86400
targets = [
    ("codex sessions", Path.home() / ".codex" / "sessions"),
    ("codex logs", Path.home() / ".codex" / "log"),
    ("codex shell snapshots", Path.home() / ".codex" / "shell_snapshots"),
    ("claude projects", Path.home() / ".claude" / "projects"),
    ("claude file history", Path.home() / ".claude" / "file-history"),
    ("claude paste cache", Path.home() / ".claude" / "paste-cache"),
]

def prune_file(path: Path) -> int:
    try:
        size = path.stat().st_size
    except FileNotFoundError:
        return 0
    path.unlink(missing_ok=True)
    return size

removed_files = 0
removed_bytes = 0

for label, root in targets:
    if not root.exists():
        continue
    for path in sorted(root.rglob("*"), reverse=True):
        try:
            stat = path.stat()
        except FileNotFoundError:
            continue
        if path.is_file() and stat.st_mtime < cutoff:
            removed_bytes += prune_file(path)
            removed_files += 1
    for path in sorted(root.rglob("*"), reverse=True):
        if path.is_dir():
            try:
                next(path.iterdir())
            except StopIteration:
                path.rmdir()
            except OSError:
                pass

def human_size(num: int) -> str:
    units = ["B", "KB", "MB", "GB", "TB"]
    value = float(num)
    for unit in units:
        if value < 1024 or unit == units[-1]:
            return f"{value:.1f}{unit}"
        value /= 1024
    return f"{num}B"

print(
    f"Autoclean pruned {removed_files} old session/history files older than "
    f"{retention_days} days ({human_size(removed_bytes)} reclaimed)."
)
PY
}

session_exists() {
  tmux has-session -t "${SESSION_NAME}" 2>/dev/null
}

legacy_session_exists() {
  tmux has-session -t "${LEGACY_SESSION_NAME}" 2>/dev/null
}

is_expected_process() {
  local port="$1"
  local needle="$2"
  local pid
  pid="$(listener_pid "$port" 2>/dev/null || true)"
  if [[ -z "${pid}" ]]; then
    return 1
  fi
  [[ "$(pid_command "$pid")" == *"${needle}"* ]]
}

wait_for_listener() {
  local port="$1"
  local attempts="${2:-40}"
  local sleep_seconds="${3:-0.5}"
  local i
  for ((i = 0; i < attempts; i += 1)); do
    if listener_pid "$port" >/dev/null 2>&1; then
      return 0
    fi
    sleep "${sleep_seconds}"
  done
  return 1
}

kill_graph_processes() {
  local kind="$1"
  local pids
  pids="$(graph_process_pids "${kind}" || true)"
  if [[ -z "${pids}" ]]; then
    return 0
  fi
  while IFS= read -r pid; do
    [[ -z "${pid}" ]] && continue
    kill "${pid}" 2>/dev/null || true
  done <<<"${pids}"
  sleep 1
  while IFS= read -r pid; do
    [[ -z "${pid}" ]] && continue
    if kill -0 "${pid}" 2>/dev/null; then
      kill -9 "${pid}" 2>/dev/null || true
    fi
  done <<<"${pids}"
}

print_stray_frontend_status() {
  python3 - "${ROOT_DIR}" "${FRONTEND_PORT}" <<'PY'
import re
import subprocess
import sys
from pathlib import Path

root_dir = Path(sys.argv[1]).resolve()
expected_port = sys.argv[2]
result = subprocess.run(["ss", "-ltnp"], capture_output=True, text=True, check=False)
found = []
for line in result.stdout.splitlines():
    m_port = re.search(r":(\d+)\b", line)
    m_pid = re.search(r"pid=(\d+)", line)
    if not m_port or not m_pid:
        continue
    port = m_port.group(1)
    if port == expected_port:
        continue
    pid = m_pid.group(1)
    try:
        cwd = Path(Path(f"/proc/{pid}/cwd").resolve()).resolve()
        cmd = Path(f"/proc/{pid}/cmdline").read_bytes().replace(b"\x00", b" ").decode("utf-8", "ignore").strip()
    except (FileNotFoundError, PermissionError, OSError):
        continue
    if cwd == root_dir and ("next dev" in cmd or "next-server" in cmd):
        found.append((port, pid, cmd))

for port, pid, cmd in found:
    print(f"warning: stray graph frontend listener on :{port} (pid {pid})")
    print(f"         {cmd}")
PY
}

print_port_status() {
  local label="$1"
  local port="$2"
  local pid
  pid="$(listener_pid "$port" 2>/dev/null || true)"
  if [[ -n "${pid}" ]]; then
    printf "%-10s %s (pid %s)\n" "${label}" "listening on :${port}" "${pid}"
    printf "           %s\n" "$(pid_command "$pid")"
  else
    printf "%-10s not listening on :%s\n" "${label}" "${port}"
  fi
}

start_session() {
  if session_exists; then
    echo "tmux session '${SESSION_NAME}' already exists."
    return 0
  fi

  kill_graph_processes frontend
  kill_graph_processes engine

  if listener_pid "${FRONTEND_PORT}" >/dev/null 2>&1 || listener_pid "${ENGINE_PORT}" >/dev/null 2>&1; then
    echo "Dev ports are already in use outside the '${SESSION_NAME}' tmux session." >&2
    echo "Use '$0 restart' to replace the current frontend/engine processes." >&2
    return 1
  fi

  if [[ "${GRAPH_DEV_AUTOCLEAN}" != "0" ]]; then
    prune_history
  fi

  tmux new-session -d -s "${SESSION_NAME}" -n frontend bash -lc "${FRONTEND_CMD}"
  tmux new-window -t "${SESSION_NAME}" -n engine bash -lc "${ENGINE_CMD}"
  tmux set-option -t "${SESSION_NAME}" remain-on-exit on >/dev/null

  if ! wait_for_listener "${FRONTEND_PORT}" 180 0.5; then
    echo "Frontend did not start on :${FRONTEND_PORT}." >&2
    return 1
  fi
  if ! wait_for_listener "${ENGINE_PORT}" 180 0.5; then
    echo "Engine did not start on :${ENGINE_PORT}." >&2
    return 1
  fi

  echo "Started SoleMD.Graph dev session in tmux: ${SESSION_NAME}"
  status_session
}

stop_tmux_session() {
  if session_exists; then
    tmux kill-session -t "${SESSION_NAME}"
  fi
  if legacy_session_exists; then
    tmux kill-session -t "${LEGACY_SESSION_NAME}"
  fi
}

stop_stray_listener() {
  local port="$1"
  local needle="$2"
  local pid
  pid="$(listener_pid "$port" 2>/dev/null || true)"
  if [[ -z "${pid}" ]]; then
    return 0
  fi
  if [[ "$(pid_command "$pid")" == *"${needle}"* ]]; then
    kill "${pid}" 2>/dev/null || true
    sleep 1
    if kill -0 "${pid}" 2>/dev/null; then
      kill -9 "${pid}" 2>/dev/null || true
    fi
  fi
}

stop_session() {
  stop_tmux_session
  kill_graph_processes frontend
  kill_graph_processes engine
  stop_stray_listener "${FRONTEND_PORT}" "next-server"
  stop_stray_listener "${ENGINE_PORT}" "uvicorn"
  pkill -f "node .*next dev" 2>/dev/null || true
  pkill -f "uv run uvicorn app.main:app --host 0.0.0.0 --port ${ENGINE_PORT}" 2>/dev/null || true
  sleep 1
  echo "Stopped SoleMD.Graph dev processes."
  status_session
}

restart_session() {
  stop_session
  start_session
}

clean_session() {
  stop_session
  prune_history
}

attach_session() {
  if ! session_exists; then
    echo "No tmux session named '${SESSION_NAME}'. Use: $0 start" >&2
    exit 1
  fi
  exec tmux attach -t "${SESSION_NAME}"
}

status_session() {
  echo "Session: ${SESSION_NAME}"
  if session_exists; then
    echo "tmux: running"
  else
    echo "tmux: not running"
  fi
  print_port_status "frontend" "${FRONTEND_PORT}"
  print_port_status "engine" "${ENGINE_PORT}"
  print_stray_frontend_status
  echo "frontend url: http://127.0.0.1:${FRONTEND_PORT}"
  echo "engine url:   http://127.0.0.1:${ENGINE_PORT}/api/v1/wiki/pages"
}

interactive_menu() {
  status_session
  if session_exists || listener_pid "${FRONTEND_PORT}" >/dev/null 2>&1 || listener_pid "${ENGINE_PORT}" >/dev/null 2>&1; then
    echo
    read -r -p "[a]ttach, [r]estart, [s]top, [q]uit: " choice
    case "${choice}" in
      a|A) attach_session ;;
      r|R) restart_session ;;
      s|S) stop_session ;;
      q|Q|"") exit 0 ;;
      *) echo "Unknown choice: ${choice}" >&2; exit 1 ;;
    esac
  else
    echo
    read -r -p "[s]tart, [q]uit: " choice
    case "${choice}" in
      s|S) start_session ;;
      q|Q|"") exit 0 ;;
      *) echo "Unknown choice: ${choice}" >&2; exit 1 ;;
    esac
  fi
}

main() {
  local action="${1:-menu}"
  case "${action}" in
    start) start_session ;;
    stop) stop_session ;;
    restart) restart_session ;;
    clean) clean_session ;;
    status) status_session ;;
    attach) attach_session ;;
    menu) interactive_menu ;;
    *)
      echo "Usage: $0 [start|stop|restart|clean|status|attach]" >&2
      exit 1
      ;;
  esac
}

main "$@"
